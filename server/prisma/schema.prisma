// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  clerkId String @unique
  email String @unique 
  imageUrl String? 
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  onboarding_complete Boolean @default(false)

  applications Application[]
  auditLogs AuditLog[]
  tailoringSessions TailoringSession[] 
  tailoredResume TailoredResume[]
  resume Resume?
}

enum Status {
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

enum AuditEvent {
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  ONBOARDING_COMPLETED
  APPLICATION_CREATED
  APPLICATION_UPDATED
  APPLICATION_DELETED
  RESUME_UPLOADED
  TAILORING_SESSION_CREATED 
  TAILORING_SUGGESTIONS_REVIEWED
  RESUME_TAILORED
}

enum TailoringSessionStatus {
  PENDING 
  REVIEWED 
  TAILORED
}

model Application {
  id String @id @default(uuid())
  role String 
  company String 
  status Status @default(APPLIED)
  appliedDate DateTime @default(now())

  notes String?
  jobUrl String? 

  userId String 
  user User @relation(fields: [userId], references:[clerkId])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tailoringSession TailoringSession[]
  tailoredResume TailoredResume[]
  @@index([userId])
}

model Resume {
  id String @id @default(uuid())
  key String 
  
  userId String 
  user User @relation(fields: [userId], references:[clerkId])

  text String @db.Text

  uploadedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
}

model AuditLog{
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references:[clerkId])

  event AuditEvent
  description String? 
  entityType String?
  entityId String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([entityType])
  @@index([event])
}

model TailoringSession{
  id String @id @default(uuid())
  applicationId String 
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  userId String
  user User @relation(fields: [userId], references:[clerkId], onDelete: Cascade)

  // Feedback from OpenAI 
  suggestions Json 

  acceptedSuggestions String[] @default([])
  dismissedSuggestions String[] @default([])

  status TailoringSessionStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tailoredResume TailoredResume[]

  @@index([userId])
  @@index([applicationId])
}

model TailoredResume {
  id String @id @default(uuid())
  key String

  tailoringSessionId String
  tailoringSession TailoringSession @relation(fields: [tailoringSessionId], references: [id], onDelete: Cascade)

  applicationId String 
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  userId String 
  user User @relation(fields: [userId], references:[clerkId], onDelete: Cascade)

  name String 
  content String @db.Text 

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([applicationId])
  @@index([tailoringSessionId])
}